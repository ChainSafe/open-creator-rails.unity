version: "1.0"
scope: "open-creator-rails.unity"
inherits: "../.invariants"

# Unity SDK assertions. These extend the apex invariants with guarantees
# specific to the C# Unity SDK implementation.
# Maintainer: Unity SDK team — not agent-writable.

asserts:

  - id: subscriber_identity_derivation
    claim: "Unity SDK derives subscriber bytes32 as keccak256(abi.encode(subscriberId, address)) — identical to the on-chain formula in Asset.cancelSubscription and to the TypeScript SDK"
    source: codebase
    severity: FROZEN
    verify:
      search: "SubscriberToId subscriberId address keccak256 abi.encode Unity Extensions"
      in_file: "open-creator-rails.unity/io.chainsafe.open-creator-rails/Runtime/Utils/Extensions.cs"
    why: "Both fields are required. Using address-only or string-only hashing produces a different bytes32, making subscriptions registered by one SDK invisible to the other and making self-cancellation impossible."

  - id: has_access_rpc_fallback
    claim: "HasAccess falls back to on-chain RPC call when indexer is unavailable"
    source: codebase
    severity: VERSIONED
    verify:
      search: "HasAccess RPC fallback on-chain Unity indexer unavailable"
    why: "On-chain state is authoritative. An indexer-only HasAccess silently denies valid access during indexer outages."

  - id: cancel_commitment_protocol
    claim: "Subscriber-initiated cancellation uses the two-step commit-reveal flow: commitCancellation(subscriberId) followed by cancelSubscription(subscriberId, timestamp, signature)"
    source: codebase
    severity: VERSIONED
    verify:
      search: "commitCancellation cancelSubscription two-step Unity Asset"
      in_file: "open-creator-rails.unity/io.chainsafe.open-creator-rails/Runtime/Asset.cs"
    cascades_from: "/.invariants#cancel_commitment_protocol"
    why: "Single-step cancellation (revokeSubscription) is owner-only. The two-step pattern is required for subscriber self-service cancellation and prevents front-running via the commit-reveal design."